{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NSEAP Prompt Item",
  "type": "object",
  "required": ["id", "title", "type", "audience", "tags", "status", "updated", "prompt"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^kb-prompt-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "const": "prompt"
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["student", "teacher", "builder", "agent"]
      },
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "stable", "sample", "deprecated"]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "prompt": {
      "type": "string"
    }
  }
}

